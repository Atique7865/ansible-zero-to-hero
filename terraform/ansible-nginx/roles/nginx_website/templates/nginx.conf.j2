server {
    listen {{ nginx_port }};
    server_name {{ nginx_server_name }};

    root {{ nginx_web_root }};
    index index.html index.htm;

    access_log /var/log/nginx/website_access.log;
    error_log  /var/log/nginx/website_error.log;

    location / {
        try_files $uri $uri/ =404;
    }
}
